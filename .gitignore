# Dependencies
node_modules/

# Build output
dist/

# Test coverage
coverage/

# Playwright
playwright-report/
test-results/
.playwright/

# Local perf runs write to a separate file to avoid dirtying the CI-owned
# `perf/results.json` (which is already tracked and thus not affected by
# `.gitignore` anyway). CI sets CI=true and writes the committed file;
# local runs write `perf/results.local.json`.
perf/results.local.json

# Test fixtures (downloaded) and rendered outputs (generated)
tests/fixtures/
tests/rendered/

# IDE
.idea/

# Claude
/.claude/
# Environment
.env
.env.*

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Lock files (keep pnpm-lock.yaml)
package-lock.json
yarn.lock
