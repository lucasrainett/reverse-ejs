{
  "name": "reverse-ejs",
  "version": "0.0.2",
  "description": "Extract data objects from rendered EJS templates",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "browser": "dist/index.global.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "/dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "format": "prettier --write --ignore-unknown .",
    "lint": "eslint src",
    "test": "vitest run --coverage",
    "download-fixtures": "tsx scripts/download-fixtures.ts",
    "generate-data": "tsx scripts/generate-data.ts",
    "render-fixtures": "tsx scripts/render-fixtures.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yaml,yml,md}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lucasrainett/reverse-ejs"
  },
  "license": "MIT",
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@eslint/js": "^10.0.1",
    "@types/ejs": "^3.1.5",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.1",
    "ejs": "^5.0.1",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  },
  "packageManager": "pnpm@10.11.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}