{
  "name": "reverse-ejs",
  "version": "3.1.0",
  "description": "Extract data objects from rendered EJS templates",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "browser": "dist/index.global.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "/dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && pnpm build:dts",
    "build:dts": "dts-bundle-generator -o dist/index.d.ts --project tsconfig.json src/index.ts && cp dist/index.d.ts dist/index.d.mts",
    "clean": "rm -rf dist",
    "format": "prettier --write --ignore-unknown .",
    "lint": "eslint src docs e2e perf playwright.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:headed": "PW_SLOW_MO=300 playwright test --headed --workers=1",
    "e2e:debug": "playwright test --debug",
    "perf": "tsx perf/run.ts",
    "perf:limits": "tsx perf/run.ts --limits",
    "perf:bench": "tsx perf/run.ts --bench",
    "perf:compare": "tsx perf/compare.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yaml,yml,md}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lucasrainett/reverse-ejs"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/ejs": "^3.1.5",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.1",
    "dts-bundle-generator": "^9.5.1",
    "ejs": "^5.0.2",
    "eslint": "^10.1.0",
    "fast-check": "^4.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
